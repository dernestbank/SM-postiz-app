# Copy to postiz.env (gitignored) or run: bash scripts/render-postiz-env.sh
#
# Production (Cloudflare: smm.quantgist.com → origin :4007)
MAIN_URL=https://smm.quantgist.com
FRONTEND_URL=https://smm.quantgist.com
NEXT_PUBLIC_BACKEND_URL=https://smm.quantgist.com/api
#
# Local-only alternative:
# MAIN_URL=http://localhost:4007
# FRONTEND_URL=http://localhost:4007
# NEXT_PUBLIC_BACKEND_URL=http://localhost:4007/api
BACKEND_INTERNAL_URL=http://localhost:3000
JWT_SECRET=change-me-use-render-script
DATABASE_URL=postgresql://postiz-user:postiz-password@postiz-postgres:5432/postiz-db-local
REDIS_URL=redis://postiz-redis:6379
TEMPORAL_ADDRESS=temporal:7233
IS_GENERAL=true
DISABLE_REGISTRATION=false
RUN_CRON=true
STORAGE_PROVIDER=local
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads
API_LIMIT=90
# X: OAuth 1.0a Consumer Key/Secret (sm_credential.md X_Consumer_key / X_Secret_key)
# NOT OAuth 2.0 Client ID. Callback: {FRONTEND_URL}/integrations/social/x
X_API_KEY=
X_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_PAGE_CLIENT_ID=
LINKEDIN_PAGE_CLIENT_SECRET=
# Meta app credentials (not page access token). Callback: .../integrations/social/facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
